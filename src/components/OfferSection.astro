---
import { Picture } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import imgTufting    from '../assets/images/offer-tufting.jpg';
import imgFelting    from '../assets/images/offer-felting.jpg';
import imgPunchNeedle from '../assets/images/offer-punch-needle.jpg';
import imgLoom       from '../assets/images/offer-loom.jpg';

const lang = getLangFromUrl(Astro.url);
const t    = useTranslations(lang);

const techniques = [
  { name: t('offer.tufting.name'),    desc: t('offer.tufting.desc'),    img: imgTufting,     width: 4000, height: 3000, alt: 'Persona trabajando con pistola de tufting en el taller Borrissol, Mataró' },
  { name: t('offer.embroidery.name'), desc: t('offer.embroidery.desc'), img: imgFelting,     width: 640,  height: 640,  alt: 'Figuras de animales creadas con técnica de fieltro agujado' },
  { name: t('offer.punch.name'),      desc: t('offer.punch.desc'),      img: imgPunchNeedle, width: 3000, height: 4000, alt: 'Tote bag con diseño colorido hecho con técnica punch needle' },
  { name: t('offer.loom.name'),       desc: t('offer.loom.desc'),       img: imgLoom,        width: 960,  height: 720,  alt: 'Manos tejiendo en un telar con hilos de colores' },
];
---

<section id="offer" class="offer-section" aria-labelledby="offer-heading">

  <!-- ── Block 1: General presentation ── -->
  <div class="offer-block-1">
    <p class="section-eyebrow reveal">{t('offer.eyebrow')}</p>
    <h2 id="offer-heading" class="offer-headline reveal" data-delay="1">{t('offer.headline')}</h2>
    <p class="offer-body reveal" data-delay="2">{t('offer.body')}</p>

    <div class="offer-grid">
      {techniques.map(({ name, desc, img, width, height, alt }, i) => (
        <article class="technique-card reveal" data-delay={i > 0 ? String(i) : undefined}>
          <div class="technique-img-wrap">
            <Picture
              src={img}
              widths={[400, 600, 800]}
              sizes="(max-width: 767px) 50vw, 25vw"
              formats={['avif', 'webp']}
              alt={alt}
              width={width}
              height={height}
              loading="lazy"
              class="technique-img"
            />
          </div>
          <div class="technique-body">
            <h3 class="technique-name">{name}</h3>
            <p class="technique-desc">{desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>

</section>

<style>
  /* ── Section wrapper ── */
  .offer-section {
    background: var(--color-white);
  }

  /* ── Shared text styles ── */
  .section-eyebrow {
    font-size: var(--font-size-ui);
    font-weight: var(--font-weight-btn);
    letter-spacing: var(--letter-spacing-btn);
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 var(--space-sm);
  }

  .offer-headline {
    font-size: var(--font-size-h2);
    font-weight: var(--font-weight-heading);
    line-height: var(--line-height-heading);
    letter-spacing: var(--letter-spacing-heading);
    color: var(--color-black);
    margin: 0 0 var(--space-md);
  }

  .offer-body {
    font-size: var(--font-size-p2);
    font-weight: var(--font-weight-body);
    line-height: var(--line-height-body);
    letter-spacing: var(--letter-spacing-body);
    color: var(--color-black);
    margin: 0;
    max-width: 640px;
  }

  /* ════════════════════════════════════════════════
     Block 1 — presentation + technique grid
     ════════════════════════════════════════════════ */
  .offer-block-1 {
    padding: var(--layout-page-padding-v) var(--layout-page-padding-h);
  }

  .offer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-sm);
    margin-top: var(--space-lg);
  }

  /* ── Card ── */
  .technique-card {
    border: var(--border-default);
    border-radius: var(--radius-xs);
    overflow: hidden;
    background: var(--color-white);
  }

  /* ── Image ── */
  .technique-img-wrap {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .technique-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .technique-card:hover .technique-img {
    transform: scale(1.04);
  }

  /* ── Text body ── */
  .technique-body {
    padding: var(--space-sm) var(--space-md) var(--space-md);
  }

  .technique-name {
    font-size: var(--font-size-h4);
    font-weight: var(--font-weight-heading);
    line-height: var(--line-height-heading);
    letter-spacing: var(--letter-spacing-heading);
    color: var(--color-black);
    margin: 0 0 var(--space-xs);
  }

  .technique-desc {
    font-size: var(--font-size-p3);
    font-weight: var(--font-weight-body);
    line-height: var(--line-height-body);
    letter-spacing: var(--letter-spacing-body);
    color: var(--color-muted);
    margin: 0;
  }

  /* ════════════════════════════════════════════════
     Tablet (≤ 1024px)
     ════════════════════════════════════════════════ */
  @media (max-width: 1024px) {
    .offer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ════════════════════════════════════════════════
     Mobile (≤ 767px)
     ════════════════════════════════════════════════ */
  @media (max-width: 767px) {
    .offer-block-1 {
      padding: var(--space-lg) var(--space-sm);
    }

    .offer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-xs);
    }

    .technique-body {
      padding: var(--space-xs) var(--space-sm) var(--space-sm);
    }
  }
</style>
