---
import { SITE } from '../config/site';
import { getLangFromUrl, getAlternatePath, localeMap } from '../i18n/utils';
import { languages, defaultLang, type Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  /** 'website' for pages, 'article' for blog posts, 'product' for shop items */
  ogType?: 'website' | 'article' | 'product';
  canonicalUrl?: string;
  noindex?: boolean;
  // Article-specific Open Graph properties
  publishedAt?: Date;
  updatedAt?: Date;
  author?: string;
}

const {
  title,
  description,
  ogImage = SITE.defaultOgImage,
  ogType = 'website',
  canonicalUrl = Astro.site
    ? new URL(Astro.url.pathname, Astro.site).href
    : Astro.url.href,
  noindex = false,
  publishedAt,
  updatedAt,
  author,
} = Astro.props;

const fullTitle    = `${title} · ${SITE.name}`;
const origin       = (Astro.site ?? Astro.url).origin;
const absOgImage   = new URL(ogImage, origin).href;
const absLogo      = new URL(SITE.logo, origin).href;
const absOgDefault = new URL(SITE.defaultOgImage, origin).href;

const currentLang  = getLangFromUrl(Astro.url);
const hreflangLinks = (Object.keys(languages) as Lang[]).map(l => ({
  lang: l,
  href: `${origin}${getAlternatePath(Astro.url, l)}`,
}));
const xDefaultHref = `${origin}${getAlternatePath(Astro.url, defaultLang)}`;

// ── Schema.org JSON-LD ────────────────────────────────────────────────────────
// Build address only when at least the country code is present
const { address } = SITE.business;
const schemaAddress = address.addressCountry
  ? {
      '@type': 'PostalAddress',
      ...(address.streetAddress   && { streetAddress:   address.streetAddress }),
      ...(address.addressLocality && { addressLocality: address.addressLocality }),
      ...(address.addressRegion   && { addressRegion:   address.addressRegion }),
      ...(address.postalCode      && { postalCode:      address.postalCode }),
      addressCountry: address.addressCountry,
    }
  : undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': SITE.business.type,
  name:        SITE.business.name,
  url:         origin,
  logo: {
    '@type': 'ImageObject',
    url: absLogo,
  },
  image:       absOgDefault,
  description: SITE.business.description,
  ...(SITE.business.email     && { email:     SITE.business.email }),
  ...(SITE.business.telephone && { telephone: SITE.business.telephone }),
  ...(schemaAddress            && { address:   schemaAddress }),
  ...(SITE.business.priceRange        && { priceRange:    SITE.business.priceRange }),
  ...(SITE.business.openingHours?.length && { openingHours: SITE.business.openingHours }),
  ...(SITE.business.sameAs?.length       && { sameAs:       SITE.business.sameAs }),
};
---

<!-- ── Primary SEO ──────────────────────────────────────────────────────────── -->
<title>{fullTitle}</title>
<meta name="description"  content={description} />
<link rel="canonical"     href={canonicalUrl} />
<meta name="robots"       content={noindex ? 'noindex, nofollow' : 'index, follow'} />

<!-- ── Open Graph ─────────────────────────────────────────────────────────── -->
<meta property="og:type"        content={ogType} />
<meta property="og:locale"      content={localeMap[currentLang]} />
<meta property="og:site_name"   content={SITE.name} />
<meta property="og:title"       content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url"         content={canonicalUrl} />
<meta property="og:image"       content={absOgImage} />
<meta property="og:image:alt"   content={fullTitle} />

{publishedAt && <meta property="article:published_time" content={publishedAt.toISOString()} />}
{updatedAt   && <meta property="article:modified_time"  content={updatedAt.toISOString()} />}
{author      && <meta property="article:author"         content={author} />}

<!-- ── Hreflang ─────────────────────────────────────────────────────────── -->
{hreflangLinks.map(({ lang, href }) => (
  <link rel="alternate" hreflang={lang} href={href} />
))}
<link rel="alternate" hreflang="x-default" href={xDefaultHref} />

<!-- ── Schema.org JSON-LD ────────────────────────────────────────────────── -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
