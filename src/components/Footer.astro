---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { WHATSAPP_HREF } from '../config';

const lang = getLangFromUrl(Astro.url);
const t    = useTranslations(lang);

const INSTAGRAM_HREF = 'https://www.instagram.com/borrissol_espai_creatiu/';
const MAPS_HREF      = 'https://maps.app.goo.gl/PVvxzbJMCfh1zR316';
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">

      <!-- Col 1: Brand -->
      <div class="footer-col reveal">
        <span class="footer-wordmark logo-wordmark">BORRISSOL<span class="footer-dot">·</span></span>
        <p class="footer-desc">{t('footer.desc')}</p>
      </div>

      <!-- Col 2: Navigation -->
      <div class="footer-col reveal" data-delay="1">
        <p class="footer-col-title">{t('footer.nav.title')}</p>
        <ul class="footer-links" role="list">
          <li><a href="#workshops">{t('nav.workshops')}</a></li>
          <li><a href="#process">{t('nav.process')}</a></li>
          <li><a href="#about">{t('nav.about')}</a></li>
          <li><a href="#faq">FAQ</a></li>
        </ul>
      </div>

      <!-- Col 3: Contact -->
      <div class="footer-col reveal" data-delay="2">
        <p class="footer-col-title">{t('footer.contact.title')}</p>
        <ul class="footer-links" role="list">
          <li><a href={WHATSAPP_HREF} target="_blank" rel="noopener noreferrer">WhatsApp</a></li>
          <li><a href={INSTAGRAM_HREF} target="_blank" rel="noopener noreferrer">@borrissol_espai_creatiu</a></li>
          <li><a href={MAPS_HREF} target="_blank" rel="noopener noreferrer">Google Maps</a></li>
          <li><span class="footer-location">Mataró, Barcelona</span></li>
        </ul>
      </div>

    </div>
  </div>

  <div class="footer-bottom reveal" data-delay="3">
    <p class="footer-copyright">{t('footer.copyright')}</p>
  </div>

  <!-- Privacy policy — anchor target for cookie banner link -->
  <div id="politica-privacitat" class="footer-privacy reveal" data-delay="4">
    <p class="footer-privacy-title">{t('privacy.title')}</p>
    <p class="footer-privacy-text">{t('privacy.text')}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-dark);
  }

  /* ── Main grid ── */
  .footer-inner {
    padding: var(--space-xl) var(--space-lg);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: var(--space-xl);
  }

  /* ── Brand column ── */
  .footer-wordmark {
    display: block;
    font-size: var(--font-size-h4);
    color: var(--color-white);
    margin-bottom: var(--space-sm);
    letter-spacing: 0.04em;
  }

  .footer-dot {
    color: var(--color-light);
    margin-left: 1px;
  }

  .footer-desc {
    font-size: var(--font-size-p3);
    font-weight: var(--font-weight-body);
    line-height: var(--line-height-body);
    letter-spacing: var(--letter-spacing-body);
    color: var(--color-light);
  }

  /* ── Nav / contact columns ── */
  .footer-col-title {
    font-size: var(--font-size-ui);
    font-weight: var(--font-weight-btn);
    letter-spacing: var(--letter-spacing-btn);
    text-transform: uppercase;
    color: var(--color-white);
    margin-bottom: var(--space-sm);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .footer-links a {
    font-size: var(--font-size-p3);
    font-weight: var(--font-weight-body);
    color: var(--color-light);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-links a:hover {
    color: var(--color-white);
  }

  .footer-location {
    font-size: var(--font-size-p3);
    color: var(--color-light);
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    border-top: var(--border-default);
    padding: var(--space-md) var(--space-lg);
  }

  .footer-copyright {
    font-size: var(--font-size-ui);
    font-weight: var(--font-weight-body);
    color: var(--color-light);
    letter-spacing: var(--letter-spacing-body);
  }

  /* ── Privacy policy ── */
  .footer-privacy {
    border-top: var(--border-default);
    padding: var(--space-md) var(--space-lg);
  }

  .footer-privacy-title {
    font-size: var(--font-size-ui);
    font-weight: var(--font-weight-btn);
    letter-spacing: var(--letter-spacing-btn);
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 var(--space-xs);
  }

  .footer-privacy-text {
    font-size: var(--font-size-p3);
    font-weight: var(--font-weight-body);
    line-height: var(--line-height-body);
    color: var(--color-muted);
    margin: 0;
    max-width: 720px;
  }

  /* ── Tablet ── */
  @media (max-width: 840px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-lg);
    }

    .footer-col:first-child {
      grid-column: 1 / -1;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 540px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .footer-col:first-child {
      grid-column: auto;
    }
  }
</style>
