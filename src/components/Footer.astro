---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { WHATSAPP_HREF } from '../config';

const lang = getLangFromUrl(Astro.url);
const t    = useTranslations(lang);

const INSTAGRAM_HREF = 'https://www.instagram.com/borrissol_espai_creatiu/';
const TIKTOK_HREF    = 'https://www.tiktok.com/@borrissol_espai_creatiu';
const MAPS_HREF      = 'https://maps.app.goo.gl/PVvxzbJMCfh1zR316';
const MAPS_EMBED     = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2986.4712557239404!2d2.4466578!3d41.5373926!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12a4b59d4e3d8df1%3A0x5a788702cdf2045!2sBorrissol%20Espai%20Creatiu!5e0!3m2!1sen!2ses!4v1778243780752!5m2!1sen!2ses';
---

<footer class="footer">
  <div class="footer-grid">

    <!-- ── Left: contact info ── -->
    <div class="footer-info">

      <p class="footer-logo logo-wordmark">BORRISSOL<span class="footer-logo-dot">.</span></p>

      <p class="footer-desc">{t('footer.desc')}</p>

      <address class="footer-address">
        Carrer de Sant Antoni, 17, baix<br />
        08301 Mataró, Barcelona
      </address>

      <hr class="footer-rule" />

      <p class="footer-label">{t('footer.contact.title')}</p>

      <ul class="footer-links" role="list">

        <li>
          <a href={WHATSAPP_HREF} target="_blank" rel="noopener noreferrer" class="footer-link">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            <span>+34 673 247 520</span>
          </a>
        </li>

        <li>
          <a href={INSTAGRAM_HREF} target="_blank" rel="noopener noreferrer" class="footer-link">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
            <span>@borrissol_espai_creatiu</span>
          </a>
        </li>

        <li>
          <a href={TIKTOK_HREF} target="_blank" rel="noopener noreferrer" class="footer-link">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.15 8.15 0 004.77 1.52V6.75a4.85 4.85 0 01-1-.06z"/>
            </svg>
            <span>@borrissol_espai_creatiu</span>
          </a>
        </li>

        <li>
          <a href={MAPS_HREF} target="_blank" rel="noopener noreferrer" class="footer-link">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span>{t('footer.directions')}</span>
          </a>
        </li>

      </ul>
    </div>

    <!-- ── Right: map ── -->
    <div class="footer-map">
      <iframe
        src={MAPS_EMBED}
        title="Borrissol Espai Creatiu — Google Maps"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>

  </div>

  <!-- ── Copyright bar ── -->
  <div class="footer-bar">
    <p class="footer-copy">{t('footer.copyright')}</p>
  </div>
</footer>

<style>
  /* ─────────────────────────────────────────────
     Scoped palette — keeps raw values in one spot
  ───────────────────────────────────────────── */
  .footer {
    --f-bg:       #1a1a1a;
    --f-text:     #d4d4d4;
    --f-muted:    rgba(212, 212, 212, 0.5);
    --f-label:    rgba(212, 212, 212, 0.4);
    --f-ghost:    rgba(212, 212, 212, 0.35);
    --f-accent:   #a90448;
    --f-rule:     rgba(255, 255, 255, 0.08);
    --f-divider:  rgba(212, 212, 212, 0.12);

    background: var(--f-bg);
    font-family: var(--font-family-base);
  }

  /* ─────────────────────────────────────────────
     60 / 40 grid
  ───────────────────────────────────────────── */
  .footer-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    min-height: 280px;
  }

  /* ─────────────────────────────────────────────
     Left block
  ───────────────────────────────────────────── */
  .footer-info {
    padding: 3rem;
  }

  .footer-logo {
    font-size: var(--font-size-h4);
    color: var(--f-text);
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
  }

  .footer-logo-dot {
    color: var(--f-accent);
  }

  .footer-desc {
    font-size: var(--font-size-p3);
    color: var(--f-muted);
    line-height: var(--line-height-body);
    margin-bottom: 0.5rem;
  }

  .footer-address {
    font-style: normal;
    font-size: var(--font-size-p3);
    color: var(--f-muted);
    line-height: 1.7;
  }

  .footer-rule {
    border: none;
    border-top: 1px solid var(--f-divider);
    margin: 1.5rem 0;
  }

  .footer-label {
    font-size: 0.7rem;
    font-weight: var(--font-weight-btn);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--f-label);
    margin-bottom: 0.875rem;
  }

  /* ─────────────────────────────────────────────
     Contact links
  ───────────────────────────────────────────── */
  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: var(--font-size-p3);
    color: var(--f-muted);
    text-decoration: none;
    opacity: 1;
    transition: color 0.15s ease;
  }

  .footer-link svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .footer-link:hover {
    color: var(--f-accent);
    opacity: 1;
  }

  /* ─────────────────────────────────────────────
     Right block — map fills the grid cell
  ───────────────────────────────────────────── */
  .footer-map {
    position: relative;
  }

  .footer-map iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    filter: grayscale(100%);
    transition: filter 0.3s ease;
  }

  .footer-map iframe:hover {
    filter: grayscale(0%);
  }

  /* ─────────────────────────────────────────────
     Copyright bar
  ───────────────────────────────────────────── */
  .footer-bar {
    border-top: 1px solid var(--f-rule);
    padding: 1.25rem 3rem;
  }

  .footer-copy {
    font-size: 0.72rem;
    color: var(--f-ghost);
    letter-spacing: var(--letter-spacing-body);
  }

  /* ─────────────────────────────────────────────
     Tablet — stack, map fixed height
  ───────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-map {
      height: 240px;
    }
  }

  /* ─────────────────────────────────────────────
     Mobile
  ───────────────────────────────────────────── */
  @media (max-width: 768px) {
    .footer-info {
      padding: 2rem 1.5rem;
    }

    .footer-map {
      height: 220px;
    }

    .footer-bar {
      padding: 1.25rem 1.5rem;
    }
  }
</style>
