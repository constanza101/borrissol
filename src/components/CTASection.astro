---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { waHref } from '../config';

const lang = getLangFromUrl(Astro.url);
const t    = useTranslations(lang);
---

<section class="cta" aria-labelledby="cta-heading">

  <!-- Headline spans full section width, not constrained by inner wrapper -->
  <div class="cta-headline-wrap">
    <h2 id="cta-heading" class="cta-headline reveal">{t('cta.headline')}</h2>
  </div>

  <!-- Subtext, button and note in a centred column -->
  <div class="cta-inner">
    <p class="cta-subtext reveal" data-delay="1">{t('cta.subtext')}</p>
    <a href={waHref(t('wa.cta'))} class="cta-btn reveal" data-delay="2" target="_blank" rel="noopener noreferrer">
      {t('cta.btn')}
    </a>
    <p class="cta-note reveal" data-delay="3">{t('cta.note')}</p>
  </div>

</section>

<style>
  .cta {
    background: var(--color-mid);
    padding-bottom: var(--space-xl);
    text-align: center;
  }

  /* ── Full-width headline ── */
  .cta-headline-wrap {
    padding: var(--space-xl) var(--space-lg) 0;
  }

  .cta-headline {
    font-size: var(--font-size-cta);
    font-weight: var(--font-weight-heading);
    line-height: var(--line-height-heading);
    letter-spacing: var(--letter-spacing-heading);
    color: var(--color-black);
    white-space: nowrap;
    overflow: hidden;
  }

  /* ── Centred content column ── */
  .cta-inner {
    padding: var(--space-lg) var(--space-lg) 0;
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .cta-subtext {
    font-size: var(--font-size-p2);
    font-weight: var(--font-weight-body);
    line-height: var(--line-height-body);
    letter-spacing: var(--letter-spacing-body);
    color: var(--color-black);
    max-width: 480px;
  }

  /* Primary button — dark fill on light bg */
  .cta-btn {
    display: inline-block;
    background: var(--color-dark);
    color: var(--color-white);
    font-size: 0.8rem;
    font-weight: var(--font-weight-btn);
    letter-spacing: var(--letter-spacing-btn);
    text-transform: uppercase;
    text-decoration: none;
    padding: 1.2em 2em;
    border-radius: var(--radius-pill);
    transition: opacity 0.15s ease;
  }

  .cta-btn:hover {
    opacity: 0.85;
  }

  .cta-note {
    font-size: var(--font-size-ui);
    font-weight: var(--font-weight-body);
    color: var(--color-muted);
    letter-spacing: var(--letter-spacing-body);
  }

  /* ── Mobile — allow headline to wrap rather than clip on tiny screens ── */
  @media (max-width: 400px) {
    .cta-headline {
      white-space: normal;
      font-size: var(--font-size-display-alt);
    }
  }
</style>
