---
import { Picture } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import belu1 from '../assets/images/belu1.jpg';
import materialsYarn from '../assets/images/materials-yarn.jpg';

const lang = getLangFromUrl(Astro.url);
const t    = useTranslations(lang);

const tags = [
  t('about.tag2'),
  t('about.tag3'),
  t('about.tag4'),
  t('about.tag5'),
];
---

<section id="about" class="about">
  <div class="ab-inner">

    <!-- Section header -->
    <div class="ab-header">
      <span class="eyebrow reveal">{t('about.eyebrow')}</span>
      <h2 class="ab-headline reveal" data-delay="1">{t('about.headline')}</h2>
    </div>

    <!-- Block 1: Studio story — image left, text right -->
    <div class="ab-block">
      <div class="ab-img-wrap reveal">
        <Picture
          src={belu1}
          widths={[400, 700, 900]}
          sizes="(max-width: 540px) 100vw, 40vw"
          formats={['avif', 'webp']}
          alt="Belén Vilanova, fundadora de Borrissol Espai Creatiu, en el taller de arte de Mataró"
          width={612}
          height={816}
          class="ab-img ab-img--bottom"
          loading="lazy"
        />
      </div>
      <div class="ab-text reveal" data-delay="1">
        <p class="ab-p">{t('about.p1')}</p>
        <p class="ab-p">{t('about.p2')}</p>
        <p class="ab-p">{t('about.p3')}</p>
        <div class="ab-tags">
          {tags.map(tag => (
            <span class="ab-tag">{tag}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- Block: MataróTV interview -->
    <div class="ab-block ab-video-block">
      <div class="ab-text reveal" data-delay="1">
        <span class="eyebrow">{t('about.video.label')}</span>
        <h3 class="ab-subtitle">{t('about.video.headline')}</h3>
        <p class="ab-p">{t('about.video.text')}</p>
        <p class="ab-video-source">{t('about.video.source')}</p>
      </div>
      <div class="ab-video-wrap reveal" data-delay="2">
        <iframe
          src="https://www.youtube.com/embed/2BAK8-bmz0s?si=Ol5yViPuthl0ly98"
          title="Borrissol Espai Creatiu a MataróTV — Art i Part"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>

    <!-- Block 2: Materials — image left, text right -->
    <div class="ab-block ab-block--reverse">
      <div class="ab-img-wrap ab-img-wrap--landscape reveal">
        <Picture
          src={materialsYarn}
          widths={[400, 700, 900]}
          sizes="(max-width: 540px) 100vw, 40vw"
          formats={['avif', 'webp']}
          alt="Conos de hilo acrílico reciclado en colores vivos usados en los talleres textiles de Borrissol, Mataró"
          width={900}
          height={596}
          class="ab-img"
          loading="lazy"
        />
        <div class="ab-gradient" aria-hidden="true"></div>
        <img
          src="/images/fiber-fever-logo.svg"
          alt="Fiber Fever"
          width="657"
          height="150"
          class="ab-fiber-logo"
          aria-hidden="true"
        />
        <a
          href="https://www.fiberfever.es/en/about/"
          target="_blank"
          rel="noopener noreferrer"
          class="ab-img-link"
          aria-label="Fiber Fever — about"
        ></a>
      </div>
      <div class="ab-text reveal" data-delay="1">
        <div class="ab-text-header">
          <span class="eyebrow">{t('materials.eyebrow')}</span>
          <h3 class="ab-subtitle">{t('materials.headline')}</h3>
        </div>
        <p class="ab-p">{t('about.materials.p1')}</p>
        <p class="ab-p">
          {t('about.materials.p2.before')}<a href="https://www.fiberfever.es/en/about/" target="_blank" rel="noopener noreferrer" class="ab-materials-link">{t('about.materials.p2.link')}</a>{t('about.materials.p2.after')}
        </p>
        <p class="ab-p">{t('about.materials.p3')}</p>
      </div>
    </div>

  </div>
</section>

<style>
  .about {
    background: var(--color-white);
    border-top: var(--border-default);
    padding: var(--space-xl) 0;
  }

  .ab-inner {
    padding: 0 var(--space-lg);
  }

  /* ── Section header ── */
  .ab-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin-bottom: var(--space-xl);
  }

  .ab-headline {
    font-size: var(--font-size-h2);
    font-weight: var(--font-weight-heading);
    line-height: var(--line-height-heading);
    letter-spacing: var(--letter-spacing-heading);
    color: var(--color-black);
  }

  /* ── Two-column blocks ── */
  .ab-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  /* Block 1: portrait image left, text gets more room on the right */
  .ab-block:not(.ab-block--reverse) {
    grid-template-columns: 2fr 3fr;
  }

  .ab-block + .ab-block {
    margin-top: var(--space-xl);
    padding-top: var(--space-xl);
    border-top: var(--border-default);
  }

  /* ── Text column ── */
  .ab-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .ab-text-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .ab-subtitle {
    font-size: var(--font-size-h3);
    font-weight: var(--font-weight-heading);
    line-height: var(--line-height-heading);
    letter-spacing: var(--letter-spacing-heading);
    color: var(--color-black);
  }

  .ab-p {
    font-size: var(--font-size-p2);
    font-weight: var(--font-weight-body);
    line-height: var(--line-height-body);
    letter-spacing: var(--letter-spacing-body);
    color: var(--color-black);
  }

  /* ── Value tags ── */
  .ab-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .ab-tag {
    display: inline-block;
    background: var(--color-light);
    color: var(--color-muted);
    border: var(--border-default);
    font-size: var(--font-size-ui);
    font-weight: var(--font-weight-btn);
    letter-spacing: var(--letter-spacing-btn);
    text-transform: uppercase;
    padding: 5px var(--space-sm);
    border-radius: var(--radius-pill);
  }

  /* ── Video block overrides ── */
  .ab-video-block {
    grid-template-columns: 1fr 1fr;
  }

  .ab-video-source {
    font-size: var(--font-size-ui);
    font-weight: var(--font-weight-btn);
    letter-spacing: var(--letter-spacing-btn);
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .ab-video-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    min-height: 315px;
  }

  .ab-video-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  /* ── Image column ── */
  .ab-img-wrap {
    position: relative;
    border-radius: var(--radius-xs);
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .ab-gradient {
    position: absolute;
    inset: 0;
    background: var(--overlay-gradient-hero);
    pointer-events: none;
  }

  .ab-img-link {
    position: absolute;
    inset: 0;
    z-index: 10;
  }

  .ab-materials-link {
    color: inherit;
    font-weight: var(--font-weight-btn);
    text-decoration: none;
    transition: text-decoration var(--t-fast);
  }
  .ab-materials-link:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .ab-fiber-logo {
    position: absolute;
    bottom: var(--space-md);
    left: var(--space-md);
    width: 60%;
    max-width: 320px;
    height: auto;
    pointer-events: none;
  }

  .ab-img-wrap--landscape {
    aspect-ratio: 4 / 3;
  }


  .ab-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ab-img--bottom {
    object-position: bottom;
  }

  /* ── Tablet ── */
  @media (max-width: 840px) {
    .ab-block {
      gap: var(--space-lg);
    }

    .ab-headline {
      font-size: var(--font-size-h3);
    }

    .ab-subtitle {
      font-size: var(--font-size-h4);
    }
  }

  /* ── Mobile ── */
  @media (max-width: 540px) {
    .ab-inner {
      padding: 0 var(--space-sm);
    }

    .ab-block {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    /* Restore equal columns override on mobile (irrelevant once stacked) */
    .ab-block:not(.ab-block--reverse) {
      grid-template-columns: 1fr;
    }

    .ab-video-block {
      grid-template-columns: 1fr;
    }

    .ab-video-wrap {
      min-height: 220px;
    }

    .ab-headline {
      font-size: var(--font-size-h3);
    }

    .ab-subtitle {
      font-size: var(--font-size-h4);
    }
  }
</style>
